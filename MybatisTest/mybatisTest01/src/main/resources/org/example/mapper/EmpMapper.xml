<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.mapper.EmpMapper">

    <select id="findOne" resultType="Emp">
        select * from emp where EMPNO = 7499;
    </select>

    <!-- list集合查询 -->
    <select id="findEmpList" resultType="Emp">
        select * from emp;
    </select>
    
    <!-- map集合查询 -->
    <select id="findEmpMap" resultType="map">
        select * from emp;
    </select>


    <!-- 单个参数 -->
    <select id="findEmpByEmpno" resultType="Emp">
        select * from emp where EMPNO = #{empno};
    </select>


    <!-- 参数为map集合 -->
    <select id="findEmpByDeptnoAndSal" resultType="Emp">
        select * from emp where DEPTNO  = #{deptno} and SAL &gt;= #{sal};
    </select>

    <!-- 参数为对象 -->

</mapper>