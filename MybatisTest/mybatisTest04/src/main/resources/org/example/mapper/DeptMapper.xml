<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.mapper.DeptMapper">

    <!-- Dept findDeptByDeptno(Integer deptno); -->
    <select id="findDeptByDeptno" resultType="dept">
        select *
        from dept
        where DEPTNO = #{dept}
    </select>

    <!--Dept findDeptByDeptno2(Integer deptno);
      select="com.msb.mapper.EmpMapper.findEmpsByDeptno" 调用的另一个SQL语句
      javaType="list"  实体类的属性数据类型
      column="deptno"  给另一个SQL语句传入的参数列
      jdbcType="INTEGER" 参数对应JDBC的数据类型
      fetchType="eager"  加载方式 eager 积极加载  lazy延迟加载-->
    <resultMap id="deptJoinEmps" type="dept">
        <id property="deptno" column="deptno"/>
        <result property="dname" column="dname"/>
        <result property="loc" column="loc"/>
        <collection property="empList" javaType="list" select="org.example.mapper.EmpMapper.findEmpsByDeptno"
                    column="deptno" jdbcType="INTEGER" fetchType="lazy">

        </collection>
    </resultMap>

    <select id="findDeptByDeptno2" resultMap="deptJoinEmps">
        select *
        from dept
        where DEPTNO = #{deptno}
    </select>
</mapper>